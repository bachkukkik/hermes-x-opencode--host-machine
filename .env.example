# >>> hermes-x-opencode-host-config begin >>>
OPENAI_API_KEY=sk-xxxx
OPENAI_BASE_URL=http://localhost:4000
OPENCODE_ZEN_API_KEY=sk-xxxx

# DEFAULT_CONTEXT_LENGTHS — fallback context length for models not in the pin
# tables. Used by config-hermes.sh when the default model is unknown and needs
# an explicit context_length in the overlay (guarantees >=1 entry).
DEFAULT_CONTEXT_LENGTHS=200000

# OPENAI_DEFAULT_MODEL — fallback model for the LiteLLM proxy (used when no
# HERMES_DEFAULT_MODEL override is set). Also controls model.default and
# model.name in the Hermes config overlay.
OPENAI_DEFAULT_MODEL=llama_cpp/qwen3.6-27b-q4_k_m
# HERMES_DEFAULT_MODEL — override for Hermes' active model. When set, BOTH
# model.default and model.name are set to this value in the Hermes config
# overlay (they are always kept consistent). If unset, OPENAI_DEFAULT_MODEL
# is used for both.
HERMES_DEFAULT_MODEL=deepseek/deepseek-v4-pro

# ──────────────────────────────────────────────────────────────────────────────
# --- OPENCODE_*_MODEL variables: use explicit provider prefix ---
# ──────────────────────────────────────────────────────────────────────────────
#
# The recognized prefixes for OPENCODE_*_MODEL values are:
#
#   opencode/<model>    — Zen free-tier models (no API key cost, rate-limited).
#                          Uses the OPENCODE_ZEN_API_KEY for authentication.
#                          Examples: opencode/deepseek-v4-flash-free
#
#   litellm/<model>     — Routes through your LiteLLM proxy (OPENAI_BASE_URL).
#                          Supports any provider backend LiteLLM knows about.
#                          Examples: litellm/openai/gpt-4o-mini
#                                   litellm/z.ai/glm-5.2
#                                   litellm/anthropic/claude-sonnet-4-20250514
#
#   llama_cpp/<model>   — Local quantized models via llama.cpp (GGUF files).
#                          Runs entirely on your machine — zero network calls.
#                          Examples: llama_cpp/qwen3.6-27b-q4_k_m
#                                   llama_cpp/llama-3.3-70b-instruct-q4_k_m
#
# Bare model IDs are auto-resolved but explicit prefixing is STRONGLY
# recommended to make routing intent visible and prevent silent misrouting.
# OPENCODE_DEFAULT_MODEL, OPENCODE_SMALL_MODEL, OPENCODE_AGENT_MODEL, and
# OPENCODE_FALLBACK_MODEL can each independently use any of the 3 provider
# prefixes. Mix and match freely — for example, default to a local model, small
# tasks to Zen free tier, and fallback to a remote proxy.
#
# Multi-model fallback chains (comma-separated):
#   You can chain multiple models in OPENCODE_FALLBACK_MODEL so OpenCode tries
#   each in order until one succeeds. Mix provider prefixes freely within a
#   single fallback chain.
#
#   Example fallback chain (remote proxy → local model):
#     OPENCODE_FALLBACK_MODEL=litellm/z.ai/glm-5.2,llama_cpp/qwen3.6-27b-q4_k_m
#
#   Example fallback chain (Zen free → LiteLLM → local):
#     OPENCODE_FALLBACK_MODEL=opencode/deepseek-v4-flash-free,litellm/openai/gpt-4o-mini,llama_cpp/qwen3.6-27b-q4_k_m
#
# ──────────────────────────────────────────────────────────────────────────────

# Default model for all OpenCode delegation tasks (top-level, build, plan).
# Must be a Zen free-tier model to avoid burning paid quota — OR use any
# provider prefix above for custom routing.
OPENCODE_DEFAULT_MODEL=llama_cpp/qwen3.6-27b-q4_k_m

# Lightweight model for small/fast tasks (summarization, formatting, etc.).
# OPENCODE_SMALL_MODEL=opencode/deepseek-v4-flash-free

# Model for agent sub-blocks (build.model, plan.model). Overrides the default
# OPENCODE_DEFAULT_MODEL for agent operations like build and plan tasks.
# When unset, agent sub-models inherit OPENCODE_DEFAULT_MODEL.
# OPENCODE_AGENT_MODEL=litellm/deepseek/deepseek-v4-flash

# Fallback model when default/small fail. Supports comma-separated chains.
OPENCODE_FALLBACK_MODEL=llama_cpp/qwen3.6-27b-q4_k_m

# Optional: Hermes YOLO mode, delegation/goals/compression (keep existing)
HERMES_YOLO_MODE=1
HERMES_DELEGATION_MAX_ITERATIONS=50
# Optional: Model for delegated subagent conversations.
# By default, subagents inherit the parent's model. Set this to use a different
# (typically cheaper/faster) model for subagent tasks.
HERMES_DELEGATION_MODEL=openai/gpt-4o-mini

# Optional: Provider for delegated subagent conversations.
# Set alongside HERMES_DELEGATION_MODEL to route subagents to a different provider.
# If only HERMES_DELEGATION_MODEL is set, subagents inherit the parent's provider.
# HERMES_DELEGATION_PROVIDER=litellm
HERMES_GOAL_MAX_TURNS=50
# HERMES_COMPRESSION_THRESHOLD=0.76

# <<< hermes-x-opencode-host-config end <<<
