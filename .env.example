OPENAI_API_KEY=sk-xxxx
OPENAI_BASE_URL=http://localhost:4000
# OPENAI_DEFAULT_MODEL — fallback model for the LiteLLM proxy (used when no
# HERMES_DEFAULT_MODEL override is set). Also controls model.default and
# model.name in the Hermes config overlay.
OPENAI_DEFAULT_MODEL=llama_cpp/qwen3.6-27b-q4_k_m
# HERMES_DEFAULT_MODEL — override for Hermes' active model. When set, BOTH
# model.default and model.name are set to this value in the Hermes config
# overlay (they are always kept consistent). If unset, OPENAI_DEFAULT_MODEL
# is used for both.
HERMES_DEFAULT_MODEL=deepseek/deepseek-v4-pro
# OPENCODE_DEFAULT_MODEL — the free Zen model used by OpenCode for all
# delegation tasks (top-level model, small_model, agent.build.model, and
# agent.plan.model). Must be a Zen free-tier model to avoid burning paid quota.
OPENCODE_DEFAULT_MODEL=opencode/deepseek-v4-flash-free
OPENCODE_SMALL_MODEL=opencode/deepseek-v4-flash-free
OPENCODE_FALLBACK_MODEL=${OPENAI_DEFAULT_MODEL:-llama_cpp/qwen3.6-27b-q4_k_m}
OPENCODE_API_KEY=sk-xxxx

# Optional: Hermes YOLO mode, delegation/goals/compression (keep existing)
HERMES_YOLO_MODE=1
HERMES_DELEGATION_MAX_ITERATIONS=50
HERMES_GOAL_MAX_TURNS=50
# HERMES_COMPRESSION_THRESHOLD=0.76
