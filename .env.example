# Required: API key for your LLM provider
# The generator reads this from ~/.hermes/config.yaml at runtime (in-process via
# python3 — never exposed as a shell variable). Set this .env entry as the
# canonical source; the generator also falls back to config.yaml's model.api_key.
OPENAI_API_KEY=

# Required: OpenAI-compatible base URL (e.g., LiteLLM proxy, vLLM, local LLM).
# The generator queries this endpoint's /v1/models to discover available models.
# Examples:
#   http://localhost:4000               (local LiteLLM proxy)
#   https://your-litellm-proxy.com      (remote LiteLLM proxy)
OPENAI_BASE_URL=http://localhost:4000

# Required: Default model (must be available at your provider endpoint)
# All other chat models are auto-discovered from the /models endpoint at startup.
OPENAI_DEFAULT_MODEL=zai/glm-5.2

# Optional: Small model for lightweight OpenCode tasks (title generation, etc.)
# Falls back to OPENAI_DEFAULT_MODEL if not set.
# OPENAI_SMALL_MODEL=openai/gpt-4o-mini

# Optional: Per-app model overrides.
# When commented out, each app follows OPENAI_DEFAULT_MODEL (and OPENAI_SMALL_MODEL
# where applicable). Uncomment and set to use a different model for a specific app.
# HERMES_DEFAULT_MODEL=litellm/zai/glm-5.2

# Required: OpenCode Zen API key for the FREE Zen model tier.
# Sign up at https://opencode.ai/auth, add billing (free tier exists), copy key.
# {env:OPENCODE_API_KEY} in opencode.jsonc resolves to this value at runtime.
# The generator writes both OPENCODE_ZEN_API_KEY (source) and OPENCODE_API_KEY
# (target for {env:...} resolution) — they MUST have the same value.
OPENCODE_ZEN_API_KEY=***

# Required: Resolves {env:OPENCODE_API_KEY} in opencode.jsonc at runtime.
# MUST equal OPENCODE_ZEN_API_KEY. Add to ~/.hermes/.env or export in your shell.
# The generator derives this from OPENCODE_ZEN_API_KEY — set both to the same value.
OPENCODE_API_KEY=${OPENCODE_ZEN_API_KEY}

# Required: OpenCode FREE Zen model for Hermes→OpenCode delegation.
# DO NOT change this unless you accept paid-quota billing on every delegated
# coding task. The generator overrides agent.build.model and agent.plan.model
# to this value so coding subagents never burn paid token quota.
OPENCODE_FREE_MODEL=opencode/deepseek-v4-flash-free

# Optional: Runtime fallback model(s) for OpenCode.
# Accepts a single model id OR a COMMA-SEPARATED ORDERED LIST. When set, the
# opencode-runtime-fallback plugin transparently retries failed OpenCode LLM
# calls (rate limits, quota exhaustion, 5xx, timeouts, overloaded) against the
# configured chain, trying entries in declared order. Use models served by a
# DIFFERENT provider than the primary so a single outage does not take down
# both. The opencode-runtime-fallback plugin and opencode-fallback.jsonc config
# are only generated when this is set.
#
# Single-model example (backward compatible):
#   OPENCODE_FALLBACK_MODEL=litellm/zai/glm-5.2
#
# Multi-model ordered-chain example (cloud tier first, GPU last resort):
#   OPENCODE_FALLBACK_MODEL=zai/glm-5.2,llama_cpp/qwen3.6-27b-q4_k_m
#   # chain: opencode/deepseek-v4-flash-free -> litellm/zai/glm-5.2 -> litellm/llama_cpp/qwen3.6-27b-q4_k_m
#
# Each entry is independently prefix-resolved: a bare id (e.g. llama_cpp/...)
# is resolved to the litellm provider when OPENAI_BASE_URL is set, otherwise
# to opencode Zen. Prefix explicitly (opencode/... or litellm/...) to force a
# specific provider. Leave unset for no fallback.
# OPENCODE_FALLBACK_MODEL=

# Optional: Hermes YOLO mode (default: 1 = on).
# When enabled (1), sets approvals.mode: off in the generated config overlay,
# skipping dangerous-command approval prompts entirely — equivalent to running
# `hermes --yolo`. Set to 0 to restore manual approval prompts.
HERMES_YOLO_MODE=1

# Optional: Max tool-calling turns for delegate_task subagents (default: 50).
# Maps to delegation.max_iterations in the generated config overlay. The Hermes
# built-in default is 50. Increase for complex delegated tasks, decrease to cap
# subagent runtime.
HERMES_DELEGATION_MAX_ITERATIONS=50

# Optional: Max turns for /goal cross-turn goals (default: 50).
# Maps to goals.max_turns in the generated config overlay. The /goal slash command
# keeps working across turns until the goal is done or the budget is exhausted.
# The Hermes built-in default is 20; this raises it to 50 for longer autonomous runs.
HERMES_GOAL_MAX_TURNS=50

# Optional: Context compression threshold (fraction of context window, 0-1).
# When token usage reaches this fraction, the agent compresses older messages.
# Example: 0.76 triggers compression at 76% context usage. Unset = agent default.
# HERMES_COMPRESSION_THRESHOLD=0.76
